# Database — ganti password dengan nilai yang aman
DB_HOST=localhost
DB_PORT=5432
DB_USER=wtrlab
DB_PASSWORD=YOUR_DB_PASSWORD_HERE
DB_NAME=wtrlab
DB_SSLMODE=disable

# JWT — generate dengan: openssl rand -hex 32
JWT_SECRET=YOUR_JWT_SECRET_HERE

# Server
SERVER_PORT=8080

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# Cookie Secure (false untuk dev HTTP, true untuk production HTTPS)
COOKIE_SECURE=false
